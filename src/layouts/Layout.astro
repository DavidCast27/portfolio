---
import { ClientRouter } from "astro:transitions";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SEO from "@/components/SEO.astro";
import { getI18N } from "@/i18n";
import "@fontsource/onest";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
  ogType?: 'website' | 'article';
  twitter?: { site?: string; creator?: string };
  alternates?: Array<{ lang: import("@/lib/lang").Lang | 'x-default'; href: string }>;
  jsonLd?: any | any[];
}

const { description, title, canonical, noindex, ogImage, ogType, twitter, alternates, jsonLd } = Astro.props as Props;
const { currentLocale, url } = Astro;
const i18n = getI18N({ currentLocale });
const baseUrl = import.meta.env.PROD ? 'https://castri.dev' : url.origin;

// JSON-LD por defecto (Person). Permite override/extend usando la prop jsonLd
const personJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: i18n.home.name,
  jobTitle: i18n.home.role,
  url: baseUrl,
  sameAs: [
    "https://github.com/DavidCast27",
    "https://www.linkedin.com/in/davidcastrillongonzales/",
    "mailto:david.cast27@gmail.com"
  ]
};

let jsonLdToUse: any | any[] = personJsonLd;
if (typeof jsonLd !== 'undefined') {
  jsonLdToUse = Array.isArray(jsonLd) ? [personJsonLd, ...jsonLd] : [personJsonLd, jsonLd];
}
---

<!doctype html>
<html lang={currentLocale}>
  <head>
    <meta id="meta-theme-color" name="theme-color" content="#0b0b0c" />
    <script is:inline>
      // Set theme class ASAP to avoid flashes
      const stored =
        typeof localStorage !== "undefined"
          ? localStorage.getItem("theme")
          : null;
      // Default to dark when no stored preference. User choice persists.
      const theme = stored ?? "dark";
      if (theme === "dark") {
        document.documentElement.classList.add("dark");
      } else {
        document.documentElement.classList.remove("dark");
      }
      // Update theme-color for address bar to match theme
      try {
        const meta = document.getElementById("meta-theme-color");
        if (meta) meta.setAttribute("content", theme === "dark" ? "#0b0b0c" : "#fafafe");
      } catch {}
      try {
        localStorage.setItem("theme", theme);
      } catch {}
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-adsense-account" content="ca-pub-4053310127194983" />
    <SEO
      title={title}
      description={description}
      lang={(currentLocale as 'en' | 'es')}
      canonical={canonical}
      noindex={noindex}
      ogImage={ogImage}
      ogType={ogType}
      twitter={twitter}
      alternates={alternates}
      jsonLd={jsonLdToUse}
    />
    <ClientRouter />

    
    {
      import.meta.env.PROD && (
        <script
          async
          src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4053310127194983"
          crossorigin="anonymous"
        />
      )
    }
  </head>
  <body class="bg-background text-foreground w-full md:max-w-4xl mx-auto">
    <a href="#home" class="sr-only focus:not-sr-only fixed top-4 left-4 z-50 bg-background text-foreground border-2 border-border rounded px-3 py-2 shadow">
      {i18n.a11y.skip_to_content}
    </a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
